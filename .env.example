DATABASE_URL="postgresql://photoopp:photoopp@localhost:5432/photoopp?schema=public"
JWT_SECRET="change-me"
JWT_EXPIRES_IN="8h"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project-id.iam.gserviceaccount.com"
FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
PORT="3333"
CLIENT_URL="http://localhost:5173"
# Opcional: outras origens no CORS, separadas por vírgula (ex.: app aberto pelo celular na mesma rede).
# CORS_EXTRA_ORIGINS="http://192.168.0.10:5173"
# Opcional: base pública da API para URLs de /uploads (storage local). No celular, localhost aponta para o telefone.
# SERVER_PUBLIC_URL="http://192.168.0.10:3333"
# Para QR/download e câmera no celular: use o IP do PC em CLIENT_URL ao testar só no telefone, ou inclua localhost em CORS_EXTRA_ORIGINS.
# Muitos celulares exigem HTTPS para getUserMedia em IP local; use túnel (ngrok) ou HTTPS local se a câmera falhar.
